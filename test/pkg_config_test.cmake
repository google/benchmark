function(expect_pkgconfig_line file_name expected)
  file(STRINGS "${PROJECT_BINARY_DIR}/${file_name}" lines)
  list(FIND lines "${expected}" index)
  if(index EQUAL -1)
    message(FATAL_ERROR "Expected '${expected}' in ${file_name}")
  endif()
endfunction()

if(IS_ABSOLUTE "${CMAKE_INSTALL_LIBDIR}")
  set(EXPECTED_PKG_CONFIG_LIBDIR "${CMAKE_INSTALL_LIBDIR}")
else()
  set(EXPECTED_PKG_CONFIG_LIBDIR "\${exec_prefix}/${CMAKE_INSTALL_LIBDIR}")
endif()
if(IS_ABSOLUTE "${CMAKE_INSTALL_INCLUDEDIR}")
  set(EXPECTED_PKG_CONFIG_INCLUDEDIR "${CMAKE_INSTALL_INCLUDEDIR}")
else()
  set(EXPECTED_PKG_CONFIG_INCLUDEDIR "\${prefix}/${CMAKE_INSTALL_INCLUDEDIR}")
endif()

expect_pkgconfig_line("benchmark.pc" "libdir=${EXPECTED_PKG_CONFIG_LIBDIR}")
expect_pkgconfig_line("benchmark.pc" "includedir=${EXPECTED_PKG_CONFIG_INCLUDEDIR}")
expect_pkgconfig_line("benchmark_main.pc" "libdir=${EXPECTED_PKG_CONFIG_LIBDIR}")
